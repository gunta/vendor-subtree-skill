---
import CardGridSection from "../components/landing/CardGridSection.astro"
import CommandsSection from "../components/landing/CommandsSection.astro"
import FinalCtaSection from "../components/landing/FinalCtaSection.astro"
import HeroSection from "../components/landing/HeroSection.astro"
import InstallSection from "../components/landing/InstallSection.astro"
import LandingFooter from "../components/landing/LandingFooter.astro"
import LandingHeader from "../components/landing/LandingHeader.astro"
import SignalStrip from "../components/landing/SignalStrip.astro"
import WorkflowSection from "../components/landing/WorkflowSection.astro"
import { problemSection, strategySection } from "../data/landing.ts"
import MarketingLayout from "../layouts/MarketingLayout.astro"
---

<MarketingLayout
  title="ingraft"
  description="ingraft routes durable repository context for coding agents: vendored source, cache links, packs, fetches, search, and project hygiene."
>
  <LandingHeader />
  <HeroSection />
  <SignalStrip />
  <InstallSection />
  <CardGridSection section={problemSection} gridClass="problem-grid" />
  <CardGridSection section={strategySection} gridClass="strategy-grid" tileClass="strategy" />
  <CommandsSection />
  <WorkflowSection />
  <FinalCtaSection />
  <LandingFooter />
</MarketingLayout>
