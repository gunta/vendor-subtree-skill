---
/**
 * Inline SVG icons — Lucide style (24×24, currentColor strokes).
 * Keep paths small and self-contained so we never ship a font.
 *
 * Add to `icons` below as needed; pass `name` to render.
 */

interface Props {
  readonly name: keyof typeof icons
  readonly size?: number
  readonly stroke?: number
  readonly class?: string
}

const { name, size = 18, stroke = 1.75, class: className = "" } = Astro.props

// Each value is the *inner* SVG markup for its icon. Lucide paths from lucide.dev,
// licensed ISC.
const icons = {
