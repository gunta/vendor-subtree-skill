---
import { capabilitySignals } from "../../data/landing.ts"
import Icon from "../icons/Icon.astro"
---

<div class="signal-strip" aria-label="Product capabilities">
  {
    capabilitySignals.map((signal) => (
      <div class="signal">
        {signal.icon && (
          <div class="signal-icon" aria-hidden="true">
            <Icon name={signal.icon as never} size={16} stroke={1.7} />
          </div>
        )}
        <strong>{signal.title}</strong>
        <span>{signal.body}</span>
      </div>
    ))
  }
</div>
