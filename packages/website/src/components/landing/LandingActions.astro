---
import type { LandingLink } from "../../data/landing.ts"
import Icon from "../icons/Icon.astro"

interface Props {
  readonly links: ReadonlyArray<LandingLink>
}

const { links } = Astro.props
---

<div class="hero-actions">
  {
    links.map((link) => (
      <a
        class:list={[
          "cta",
          link.variant === "primary" ? "cta-primary" : "cta-secondary"
        ]}
        href={link.href}
      >
        <span>{link.label}</span>
        <Icon
          name={link.variant === "primary" ? "arrow-right" : "arrow-up-right"}
          size={15}
          stroke={1.9}
          class="cta-trail"
        />
      </a>
    ))
  }
</div>
