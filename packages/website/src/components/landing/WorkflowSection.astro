---
import { workflowItems } from "../../data/landing.ts"
import Icon from "../icons/Icon.astro"
import TerminalDemo from "./TerminalDemo.astro"
---

<section class="section">
  <p class="section-kicker">Workflow</p>
  <h2>Discovery, vendoring, editor hygiene, and status in one loop.</h2>
  <div class="workflow-grid">
    <TerminalDemo />
    <article class="tile workflow-tile">
      <h3>
        <span class="workflow-tile-icon" aria-hidden="true">
          <Icon name="zap" size={16} stroke={1.7} />
        </span>
        Made for real repositories
      </h3>
      <ul class="check-list">
        {workflowItems.map((item) => (
          <li>
            <span class="check-list-icon" aria-hidden="true">
              <Icon name="check" size={11} stroke={2.4} />
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </article>
  </div>
</section>
