---
import Icon from "../icons/Icon.astro"
import CodeWindow from "./CodeWindow.astro"

const commands = [
  {
    icon: "package",
    title: "Add durable source",
    body: "Resolve the package, pick the storage route, write source under <code>vendor/</code> when that is the right contract.",
    code: `bunx @ingraft/cli@latest add effect-ts/effect
bunx @ingraft/cli@latest add zod --strategy subtree
bunx @ingraft/cli@latest add convex --strategy cache-link`,
    lang: "bash"
  },
  {
    icon: "layers",
    title: "Use lighter routes",
    body: "Detect optional context tools, pack a narrow snapshot, or fetch source without committing it.",
    code: `bunx @ingraft/cli@latest context
bunx @ingraft/cli@latest context pack vendor/effect --compress
bunx @ingraft/cli@latest context source zod`,
    lang: "bash"
  },
  {
    icon: "stethoscope",
    title: "Doctor the project",
    body: "See the tool surfaces ingraft detected and what it changed.",
    code: `bunx @ingraft/cli@latest doctor
bunx @ingraft/cli@latest doctor --fix
bunx @ingraft/cli@latest list --json`,
    lang: "bash"
  }
] as const

const tsSample = `// vendor/effect/src/Effect.ts — fully indexable by your agent
export interface Effect<out A, out E = never, out R = never>
  extends Variance<A, E, R>, Pipeable {
  readonly [TypeId]: Effect.Variance<A, E, R>
  readonly [NodeInspectSymbol]: () => unknown
  [Symbol.iterator](): EffectGenerator<Effect<A, E, R>>
}

export const succeed: <A>(value: A) => Effect<A> = core.succeed
export const fail:    <E>(error: E) => Effect<never, E> = core.fail
export const sync:    <A>(thunk: LazyArg<A>) => Effect<A> = core.sync`
---

<section class="section commands-section">
  <p class="section-kicker">Real code, local</p>
  <h2>Your repo carries the context. Not just the chat.</h2>
  <p class="section-intro">
    Durable context lands as real files under <code class="inline">vendor/</code>; lighter context
    can be packed, fetched, linked, or searched. The point is the route: explicit enough for Claude,
    Codex, Cursor, Copilot, Jules, and whatever worker picks up the thread next.
  </p>

  <div class="commands-grid">
    {commands.map((cmd) => (
      <article class="tile command-tile">
        <header class="command-tile-head">
          <span class="command-tile-icon" aria-hidden="true">
            <Icon name={cmd.icon as never} size={16} stroke={1.7} />
          </span>
          <div>
            <h3>{cmd.title}</h3>
            <p set:html={cmd.body} />
          </div>
        </header>
        <CodeWindow code={cmd.code} lang={cmd.lang} compact />
      </article>
    ))}
  </div>

  <div class="agent-window">
    <header class="agent-window-head">
      <div class="agent-window-titlebar">
        <Icon name="code" size={14} stroke={1.7} />
        <span class="agent-window-path">vendor/effect/src/Effect.ts</span>
      </div>
      <div class="agent-window-meta">
        <span class="agent-window-pill">
          <Icon name="git-fork" size={11} stroke={1.9} />
          subtree
        </span>
        <span class="agent-window-pill">
          <Icon name="circle-dot" size={11} stroke={1.9} />
          v3.21.2
        </span>
      </div>
    </header>
    <CodeWindow code={tsSample} lang="typescript" />
  </div>
</section>
