---
import { heroActions } from "../../data/landing.ts"
import Icon from "../icons/Icon.astro"
import LandingActions from "./LandingActions.astro"
---

<section class="hero">
  <div class="hero-inner">
    <p class="eyebrow">
      <Icon name="sparkles" size={12} stroke={1.8} />
      Repository context for agentic development
    </p>
    <h1>ingraft</h1>
    <p class="hero-copy">
      Put the context your agents need where local terminals, cloud workers, PR agents, and mobile
      handoffs can all find it. Vendor source when depth matters; route docs, packs, cache links,
      and search when another path fits better.
    </p>
    <LandingActions links={heroActions} />
    <div class="hero-foot">
      <span class="hero-foot-item">
        <Icon name="package" size={13} stroke={1.7} />
        <code>npx ingraft@latest</code>
      </span>
      <span class="hero-foot-sep" aria-hidden="true">·</span>
      <span class="hero-foot-item">
        <Icon name="zap" size={13} stroke={1.7} />
        bunx / npm / brew / nix
      </span>
      <span class="hero-foot-sep" aria-hidden="true">·</span>
      <span class="hero-foot-item">
        <Icon name="git-fork" size={13} stroke={1.7} />
        vendor / pack / fetch / search
      </span>
    </div>
  </div>
</section>
