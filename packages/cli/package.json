{
  "name": "@ingraft/cli",
  "version": "0.3.2",
  "description": "Route repository context into coding-agent workflows.",
  "keywords": [
    "cli",
    "coding-agents",
    "context-routing",
    "dependency-management",
    "effect",
    "git-subtree",
    "ingraft",
    "monorepo",
    "repository-context",
    "vendor"
  ],
  "homepage": "https://ingraft.dev",
  "bugs": {
    "url": "https://github.com/gunta/ingraft/issues"
  },
  "license": "MIT",
  "author": "Gunther Brunner <gunta85@gmail.com> (https://github.com/gunta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunta/ingraft.git",
    "directory": "packages/cli"
  },
  "man": "./man/ingraft.1",
  "bin": {
    "ingraft": "dist/bin/ingraft.js"
  },
  "files": [
    "dist",
    "man",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/cli.d.ts",
      "default": "./dist/src/cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist ../../.tsbuildinfo/packages-cli-build.tsbuildinfo && tsc -p tsconfig.build.json && mkdir -p dist/src/aliases && cp src/aliases/repository-aliases.json dist/src/aliases/repository-aliases.json && chmod +x dist/bin/ingraft.js",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run check:idioms && bun run test",
    "check:idioms": "bun scripts/check-v4-idioms.ts",
    "dev": "bun scripts/vendor.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "link:dev": "bun scripts/link-dev.ts",
    "prepublishOnly": "bun run build",
    "test": "cd ../.. && bun test packages/cli/tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "unlink:dev": "bun scripts/link-dev.ts --remove"
  },
  "dependencies": {
    "@effect/platform-bun": ">=4.0.0-beta.60 || >=4.0.0",
    "@effect/platform-node": ">=4.0.0-beta.60 || >=4.0.0",
    "@iarna/toml": "2.2.5",
    "@opentui/core": "^0.2.8",
    "@xmldom/xmldom": "0.9.10",
    "effect": ">=4.0.0-beta.60 || >=4.0.0",
    "ink": "^7.0.2",
    "ioredis": "^5.10.1",
    "isomorphic-git": "^1.37.6",
    "jscodeshift": "17.3.0",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.6",
    "ts-morph": "28.0.0",
    "update-notifier": "^7.3.1",
    "yaml": "2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.11"
  }
}
