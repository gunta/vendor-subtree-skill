{
  "name": "@ingraft/tui-workspace",
  "version": "0.3.0",
  "private": true,
  "description": "OpenTUI dashboard for managing ingraft repositories.",
  "keywords": [
    "dashboard",
    "ingraft",
    "opentui",
    "terminal-ui",
    "tui"
  ],
  "homepage": "https://ingraft.dev",
  "bugs": {
    "url": "https://github.com/gunta/ingraft/issues"
  },
  "license": "MIT",
  "author": "Gunther Brunner <gunta85@gmail.com> (https://github.com/gunta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunta/ingraft.git",
    "directory": "packages/tui"
  },
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "dev": "bun src/index.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.2.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
