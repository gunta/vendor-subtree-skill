{
  "name": "ingraft",
  "version": "0.3.1",
  "description": "Compatibility entrypoint for the @ingraft/cli package.",
  "keywords": [
    "cli",
    "coding-agents",
    "context-routing",
    "ingraft",
    "repository-context"
  ],
  "homepage": "https://ingraft.dev",
  "bugs": {
    "url": "https://github.com/gunta/ingraft/issues"
  },
  "license": "MIT",
  "author": "Gunther Brunner <gunta85@gmail.com> (https://github.com/gunta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunta/ingraft.git",
    "directory": "packages/ingraft"
  },
  "bin": {
    "ingraft": "bin/ingraft.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run lint && bun run format:check",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix"
  },
  "dependencies": {
    "@ingraft/cli": "0.3.1"
  }
}
