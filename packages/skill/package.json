{
  "name": "@ingraft/skill",
  "version": "0.3.2",
  "description": "Agent skill wrapper for the ingraft repository-context CLI.",
  "keywords": [
    "agent-skill",
    "claude-code",
    "coding-agents",
    "context-routing",
    "ingraft",
    "repository-context",
    "skill",
    "vendor"
  ],
  "homepage": "https://ingraft.dev",
  "bugs": {
    "url": "https://github.com/gunta/ingraft/issues"
  },
  "license": "MIT",
  "author": "Gunther Brunner <gunta85@gmail.com> (https://github.com/gunta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunta/ingraft.git",
    "directory": "packages/skill"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run lint && bun run format:check",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern"
  }
}
