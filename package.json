{
  "name": "ingraft-workspace",
  "version": "0.3.0",
  "private": true,
  "description": "Monorepo workspace for the ingraft CLI, agent skill, TUI dashboard, and documentation website.",
  "keywords": [
    "coding-agents",
    "dependency-management",
    "git-subtree",
    "ingraft",
    "monorepo",
    "vendor"
  ],
  "homepage": "https://ingraft.dev",
  "bugs": {
    "url": "https://github.com/gunta/ingraft/issues"
  },
  "license": "MIT",
  "author": "Gunther Brunner <gunta85@gmail.com> (https://github.com/gunta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunta/ingraft.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:cli": "bun run --cwd packages/cli build",
    "build:website": "bun run --cwd packages/website build",
    "check": "turbo run check check:root",
    "check:root": "bun run lint && bun run format:check",
    "clean": "rm -rf packages/cli/dist packages/website/dist packages/website/.astro",
    "dev": "bun run dev:cli",
    "dev:cli": "bun run --cwd packages/cli dev",
    "dev:tui": "bun run --cwd packages/tui dev",
    "dev:website": "turbo run dev --filter=ingraft-website",
    "dev:website:local": "bun run --cwd packages/website dev:app",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "turbo run test",
    "tui": "bun run dev:tui",
    "typecheck": "turbo run typecheck",
    "vendor": "bun packages/cli/scripts/vendor.ts",
    "website": "bun run dev:website",
    "website:build": "bun run build:website"
  },
  "devDependencies": {
    "@types/jscodeshift": "17.3.0",
    "@types/node": "^25.7.0",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "portless": "^0.13.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
